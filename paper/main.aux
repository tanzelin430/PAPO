\newlabel{sec:training-data}{{A.2}{12}{Training Data}{subsection.A.2}{}}
\newlabel{tab:difficulty}{{5}{12}{Difficulty distribution of the stratified training set. Pass rates are measured using a reference model with 8 attempts at temperature 1.0. Equal sampling across tiers ensures balanced difficulty coverage}{table.caption.32}{}}
\newlabel{sec:rubric-prompt}{{A.3}{12}{Rubric Prompt}{subsection.A.3}{}}
\newlabel{fig:training_curves_grid}{{5}{13}{Training curves (avg@4) across two model scales and three benchmarks. Top row: Qwen2.5-3B; bottom row: Qwen2.5-7B. \method {} consistently outperforms ORM throughout training on both scales, with gains widening in later stages as ORM's signal exhaustion worsens. The pattern is consistent across OlympiadBench (competition math), MATH-500 (standard math), and HumanEval (code generation). Qwen2.5-14B results are reported in Table~\ref {tab:main_results}}{figure.caption.33}{}}
\newlabel{sec:appendix-results}{{B}{13}{Additional Results}{appendix.B}{}}
\newlabel{sec:cross-scale-curves}{{B.1}{13}{Cross-Scale Training Curves}{subsection.B.1}{}}
\newlabel{sec:rubric-analysis}{{B.3}{13}{Process Advantage Effect}{subsection.B.3}{}}
\newlabel{sec:adv-decomp}{{B.4}{13}{Advantage Composition}{subsection.B.4}{}}
\newlabel{fig:abl_fullnorm}{{6}{14}{Ablation: correct-subset normalization (\method {}) vs.\ full normalization (Fullnorm) on OlympiadBench and MATH-500. Both methods improve over ORM, but \method {}'s correct-subset design maintains a consistent advantage over Fullnorm throughout training}{figure.caption.34}{}}
\newlabel{fig:abl_mult}{{7}{14}{Ablation: decoupled normalization (\method {}) vs.\ multiplicative reward (Mult) on OlympiadBench and MATH-500. Mult improves over ORM but falls substantially short of \method {}, confirming that decoupled normalization is superior to naive reward combination}{figure.caption.35}{}}
\newlabel{fig:rubric_critic}{{8}{14}{\textbf {(a)} Minimum advantage among correct responses. ORM: identically 0.0 (all correct responses treated equally). \method {}: $\approx -1.49$ (the process advantage penalizes correct responses with poor reasoning). \textbf {(b)} Standard deviation of advantages among correct responses. ORM: zero (no differentiation). \method {}: non-zero (quality-based ranking within correct group)}{figure.caption.36}{}}
\newlabel{sec:case-study-hacking}{{B.6}{14}{Case Study: PRM Reward Hacking}{subsection.B.6}{}}
\newlabel{fig:adv_decomp}{{9}{15}{\method {} advantage composition. \textbf {(a)} Signal strength (std) of $\aout $ and $\aproc $: the outcome advantage provides the dominant gradient signal while the process advantage contributes a complementary quality signal. \textbf {(b)} Process signal active ratio: the fraction of groups where $\aproc $ is non-zero ($\geq 2$ correct responses), growing from $\sim $30\% to 70\% as the model improves. \textbf {(c)} Mean advantage by correctness: correct responses receive positive advantage while wrong responses receive negative, confirming the outcome signal functions correctly despite the added process component}{figure.caption.37}{}}
\newlabel{tab:reward_hacking_case}{{6}{16}{Response statistics across five math problems. PRM reward hacking severity correlates with problem difficulty: on easier problems (bottom three rows), PRM step-1000 is comparable to baselines; on harder problems (top two rows), responses are 2--3$\times $ longer with characteristic degeneration patterns}{table.caption.38}{}}
